kubectl -n qe-hack-syndicate create secret generic qe-quality-agent-secrets  \
  --from-literal=NEO4J_PASSWORD='bitt4sw33t'   \
  --from-literal=JIRA_API_TOKEN='ATATT3xFfGF09UumFq5rW4IoBFbDskkWns8pc8egKv_IEQR31AUZjkInk7HI0OKVt_c8ddT50yiL0MiYq0xUlZwPcU-fBx2aHlBnBUhweHjH8rj-7zpps_Toz5du2E0B43E5-PDe6X71JvUorAb2j9HAd7fj35KRkRN4VMQQsRRaujcImVV0OTc=95D3F36D'   \
  --from-literal=HARNESS_API_KEY='pat.1iW3b7HMR3-EyCF5Nhpmrg.6a25c4ba900c2f1f4ed01008.Psr44EnTrpwPHvjQlNKA'   \
  --from-literal=HARNESS_ACCOUNT_ID='1iW3b7HMR3-EyCF5Nhpmrg' --from-literal=GITHUB_TOKEN='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'  --from-literal=JIRA_WEBHOOK_TOKEN='4f0f6f53b12f2e2bcc385d2c14c41c969524e6a28b7068d2664fec6610619852'   \
  --from-literal=HARNESS_BDD_WEBHOOK_URL='https://app.harness.io/gateway/pipeline/api/webhook/custom/clwv6w73S22lXg31baT9ig/v3?accountIdentifier=1iW3b7HMR3-EyCF5Nhpmrg&orgIdentifier=default&projectIdentifier=QE_HACK&pipelineIdentifier=bdd_tests&triggerIdentifier=jira_testing_transition'


# --- 2. Apply manifests ---
kubectl -n qe-hack-syndicate apply -f qe-agent/deploy/k8s/configmap.yaml
kubectl -n qe-hack-syndicate apply -f qe-agent/deploy/k8s/deployment.yaml
kubectl -n qe-hack-syndicate apply -f qe-agent/deploy/k8s/service.yaml
kubectl -n qe-hack-syndicate apply -f qe-agent/deploy/k8s/ingress.yaml

# --- 3. Get the external load balancer IP ---
# Wait ~2 min after ingress apply for GCP to assign the IP
EXTERNAL_IP=$(kubectl -n qe-hack-syndicate get ingress qe-quality-agent-webhook \
  -o jsonpath='{.status.loadBalancer.ingress[0].ip}')
echo "External IP: $EXTERNAL_IP"

# --- 4. DNS: point qe-agent.astom.tools at the LB IP ---
# The ingress host rule is already set to qe-agent.astom.tools in ingress.yaml.
# Create (or update) the A record in the astom.tools managed zone:
DNS_PROJECT=<YOUR_DNS_GCP_PROJECT_ID>   # project that owns the astom.tools zone
DNS_ZONE_NAME=<ASTOM_TOOLS_ZONE_NAME>   # Cloud DNS zone resource name (not the DNS name)

# Create the A record (run once; use 'update' instead if the record already exists)
gcloud dns record-sets create qe-agent.astom.tools. \
  --zone="${DNS_ZONE_NAME}" \
  --type=A \
  --ttl=60 \
  --rrdatas="${EXTERNAL_IP}" \
  --project "${DNS_PROJECT}"

# Verify propagation:
dig +short qe-agent.astom.tools

# --- 5. TLS: attach the pre-shared GCP SSL certificate named qe-agent ---
# The certificate must already exist in GCP (GCP Console -> Certificate Manager
# -> Classic certificates, or via gcloud compute ssl-certificates create).
# It must cover the domain qe-agent.astom.tools.

# Confirm the cert exists and covers the right domain:
gcloud compute ssl-certificates describe qe-agent --global \
  --format='value(managed.domains)'

# Confirm cert status is ACTIVE:
gcloud compute ssl-certificates describe qe-agent --global \
  --format='value(managed.status)'

# Attach to the ingress (already set in ingress.yaml annotation; run this if
# applying to a pre-existing ingress that didn't have the annotation):
kubectl -n qe-hack-syndicate annotate ingress qe-quality-agent-webhook \
  ingress.gcp.kubernetes.io/pre-shared-cert=qe-agent --overwrite

# --- 6. Jira webhook URL ---
# Register this URL in Jira: Settings -> System -> WebHooks -> Create
echo "https://qe-agent.astom.tools/qe/jira/webhook?token=<JIRA_WEBHOOK_TOKEN>"

# Smoke test:
curl -s https://qe-agent.astom.tools/healthz

# Step 6f: verify end-to-end
curl -i "https://${SUBDOMAIN}/healthz"

# Final Jira webhook URL:
echo "https://${SUBDOMAIN}/qe/jira/webhook?token=<JIRA_WEBHOOK_TOKEN>"
#
# Notes:
# - The DNS project just needs an A record — no GCP IAM cross-project permission
#   is required between the two projects for DNS.
# - The pre-shared GCP SSL certificate `qe-agent` is reused; no new cert is created.
# - If the zone uses NS delegation (e.g. subdomain delegated from a parent zone),
#   ensure the NS records are correct first: `dig NS ${SUBDOMAIN}`
# - TTL 60s is used above for faster propagation during setup; raise to 300-3600
#   once stable.










gcloud builds submit --config deploy/cloudbuild.yaml \
  --substitutions _IMAGE=us-central1-docker.pkg.dev/project-61358164-b71e-4422-a5c/qe/qe-quality-agent:0.1.1 \
  --project <YOUR_PROJECT_ID> .




kubectl -n qe-hack-syndicate set image deployment/qe-quality-agent \
  qe-quality-agent=us-central1-docker.pkg.dev/project-61358164-b71e-4422-a5c/qe/qe-quality-agent:0.1.1



kubectl -n qe-hack-syndicate rollout status deployment/qe-quality-agent